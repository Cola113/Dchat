# OpenAI-compatible chat providers. Configure at least one group.
BASE_URL_1=https://api.example.com
KEY_1=your-provider-api-key
MODEL_1=your-model-name

# Optional fallback providers.
# BASE_URL_2=
# KEY_2=
# MODEL_2=
# BASE_URL_3=
# KEY_3=
# MODEL_3=
# BASE_URL_4=
# KEY_4=
# MODEL_4=

# Required by @vercel/blob in production when using /api/upload.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
