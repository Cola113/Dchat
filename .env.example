# OpenAI-compatible chat providers. Configure at least one group.
BASE_URL_1=https://api.example.com
KEY_1=your-provider-api-key
MODEL_1=your-model-name
# App-side context retention budget. Values below 262144 are raised to 262144.
CHAT_CONTEXT_TOKENS=262144
# First-token race timeout in milliseconds. Keep higher for slower deployed models.
CHAT_RACE_TIMEOUT_MS=12000
# Optional private owner-profile notes appended to Xiaokele's persona prompt.
OWNER_PROFILE_EXTRA_PROMPT=""

# Optional fallback providers.
# BASE_URL_2=
# KEY_2=
# MODEL_2=
# BASE_URL_3=
# KEY_3=
# MODEL_3=
# BASE_URL_4=
# KEY_4=
# MODEL_4=

# Required when saving conversation logs and uploaded images to Alibaba Cloud OSS.
# Use a RAM user with the minimum write permission for the target bucket/prefix.
ALI_OSS_REGION=oss-cn-hangzhou
ALI_OSS_BUCKET=your-chat-log-bucket
ALI_OSS_ACCESS_KEY_ID=your-access-key-id
ALI_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALI_OSS_PREFIX=chat-logs
ALI_OSS_UPLOAD_PREFIX=uploads
# Signed image URLs returned by /api/upload. Max is capped at 7 days.
ALI_OSS_UPLOAD_URL_TTL_SECONDS=86400
# Optional: use a custom bucket endpoint host, for example your-bucket.oss-cn-hangzhou.aliyuncs.com.
# ALI_OSS_ENDPOINT=
# Optional: set this when using temporary STS credentials.
# ALI_OSS_SECURITY_TOKEN=
