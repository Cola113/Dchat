# OpenAI-compatible chat providers. Configure at least one group.
# BASE_URL should include the provider API prefix/version; the app appends /chat/completions.
# Examples:
# - OpenAI-compatible v1: https://api.example.com/v1
# - Zhipu BigModel: https://open.bigmodel.cn/api/paas/v4
BASE_URL_1=https://api.example.com/v1
KEY_1=your-provider-api-key
MODEL_1=your-model-name
PROVIDER_PRIORITY_1=1
# App-side context retention budget. Values below 262144 are raised to 262144.
CHAT_CONTEXT_TOKENS=262144
# Enable Aliyun Context Cache for qwen3.7-plus compatible providers.
CHAT_CONTEXT_CACHE=0
# First-token timeout for each provider in milliseconds. Keep higher for slower deployed models.
CHAT_RACE_TIMEOUT_MS=12000
# Delay before starting the next lower-priority provider. Set 4000 for a 4-second stagger.
CHAT_PROVIDER_STAGGER_MS=4000

# Optional fallback providers.
# BASE_URL_2=
# KEY_2=
# MODEL_2=
# PROVIDER_PRIORITY_2=2
# BASE_URL_3=
# KEY_3=
# MODEL_3=
# PROVIDER_PRIORITY_3=3
# BASE_URL_4=
# KEY_4=
# MODEL_4=
# PROVIDER_PRIORITY_4=4
